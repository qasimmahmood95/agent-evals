{
  "name": "agent-evals",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic, replayable, CI-safe testing for agent tool-call trajectories: committed content-addressed fixtures, offline effect replay, trajectory policy checks, statistically grounded verdicts.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli.ts",
    "replay": "tsx src/cli.ts replay",
    "fixtures:author": "tsx scripts/author-fixtures.ts",
    "check": "tsx src/cli.ts check policies/demo-core.suite.json policies/adversarial.suite.json",
    "gate": "tsx src/cli.ts gate",
    "demo:gate": "tsx src/cli.ts gate policies/gate-villain.json",
    "baseline:author": "tsx scripts/make-baseline.ts"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
